{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "messages.data",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["sender"],
        "additionalProperties": false,
        "properties": {
          "sender":  { "type": "string", "maxLength": 20 },
          "preview": { "type": "string", "maxLength": 60 },
          "age":     { "type": "string", "maxLength": 12, "description": "e.g. '2m', '1h', 'just now'" }
        }
      }
    }
  }
}
